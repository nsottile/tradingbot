# Copy this file to .env and fill in your values.
# NEVER commit .env to version control.

# --- Anthropic ---
ANTHROPIC_API_KEY=sk-ant-...

# --- Polymarket CLOB (only needed for live trading) ---
POLYMARKET_API_KEY=
POLYMARKET_API_SECRET=
POLYMARKET_API_PASSPHRASE=

# --- Database ---
DATABASE_URL=postgresql://postgres:postgres@localhost:5432/polymarket_alpha

# --- Redis (optional) ---
# REDIS_URL=redis://localhost:6379/0

# --- Trading mode ---
# Set to false ONLY after extensive paper trading validation
PAPER_TRADING=true
# Master switch: live order routing (still requires UI confirmation + simulation off)
ENABLE_LIVE_TRADING=false
# Cap per autonomous order (USD)
MAX_ORDER_NOTIONAL_USD=5000

# --- Alpaca (stocks) ---
ALPACA_API_KEY=
ALPACA_API_SECRET=
# Optional; default paper API if unset
# ALPACA_BASE_URL=https://paper-api.alpaca.markets

# --- Binance (crypto stub — extend HMAC for production) ---
BINANCE_API_KEY=
BINANCE_API_SECRET=
# BINANCE_REST_URL=https://api.binance.com

# --- Stripe (billing scaffold) ---
STRIPE_SECRET_KEY=
STRIPE_WEBHOOK_SECRET=
STRIPE_PRICE_CREDITS_ID=

# --- Logging ---
LOG_LEVEL=INFO
LOG_JSON=true
